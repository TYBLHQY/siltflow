{
  "name": "siltflow-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm -F @siltflow/desktop dev",
    "build": "pnpm -F @siltflow/desktop build",
    "lint": "pnpm -F @siltflow/desktop lint",
