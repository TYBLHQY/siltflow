{
  "name": "siltflow-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "desktop:dev": "pnpm --filter @siltflow/desktop dev",
    "desktop:build": "pnpm --filter @siltflow/shared build && pnpm --filter @siltflow/desktop build",
    "shared:build": "pnpm --filter @siltflow/shared build",
    "shared:watch": "pnpm --filter @siltflow/shared dev",
    "desktop:rebuild": "pnpm --filter @siltflow/desktop rebuild",
    "build": "pnpm --filter @siltflow/shared build && pnpm --filter @siltflow/desktop build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec -- rm -rf dist dist-electron node_modules"
  },
  "engines": {
    "node": ">=18"
  }
}
