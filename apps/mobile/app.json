{
  "expo": {
    "name": "Siltflow",
    "slug": "siltflow",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "siltflow",
    "splash": {
      "backgroundColor": "#1e1e2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.myq.siltflow"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e1e2e"
      },
      "package": "com.myq.siltflow"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-document-picker",
      "expo-file-system"
    ]
  }
}
